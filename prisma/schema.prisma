generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Roles: ADMIN | ORGANIZATION | FARMER
// ProjectStatus: DRAFT | ACTIVE | PAUSED | COMPLETED | CANCELLED
// TreeStatus: PENDING_VERIFICATION | ACTIVE | DEAD | FLAGGED
// SubmissionStatus: PENDING_AI | AI_APPROVED | AI_REJECTED | ADMIN_REVIEW | APPROVED | REJECTED
// PayoutStatus: PENDING | PROCESSING | COMPLETED | FAILED

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  phone         String?  @unique
  passwordHash  String
  role          String   @default("FARMER")
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization  Organization?
  farmer        Farmer?
  refreshTokens RefreshToken[]
  otps          Otp[]
}

model Organization {
  id                 String   @id @default(cuid())
  userId             String   @unique
  companyName        String
  registrationNumber String?
  country            String
  website            String?
  logoUrl            String?
  description        String?
  stripeCustomerId   String?
  escrowBalance      Float    @default(0)
  totalCreditsEarned Float    @default(0)
  isKycVerified      Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id])
  projects     Project[]
  payments     Payment[]
  certificates CarbonCertificate[]
}

model Farmer {
  id                String   @id @default(cuid())
  userId            String   @unique
  fullName          String
  country           String
  idDocument        String?
  idDocumentUrl     String?
  bankAccountName   String?
  bankAccountNumber String?
  bankRoutingNumber String?
  stripeAccountId   String?
  totalEarnings     Float    @default(0)
  pendingEarnings   Float    @default(0)
  isKycVerified     Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  trees       Tree[]
  submissions Submission[]
  payouts     Payout[]
}

model Project {
  id                   String   @id @default(cuid())
  organizationId       String
  title                String
  description          String
  targetTreeCount      Int
  currentTreeCount     Int      @default(0)
  species              String   @default("mixed")
  pricePerTreePerMonth Float
  totalBudget          Float
  remainingBudget      Float
  country              String
  regionLat            Float?
  regionLng            Float?
  regionRadiusKm       Float?
  startDate            DateTime?
  endDate              DateTime?
  status               String   @default("ACTIVE")
  co2PerTreePerYear    Float    @default(22)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id])
  trees        Tree[]
  payments     Payment[]
  certificates CarbonCertificate[]
}

model Tree {
  id           String   @id @default(cuid())
  farmerId     String
  projectId    String?
  qrCode       String   @unique @default(cuid())
  species      String
  lat          Float
  lng          Float
  address      String?
  plantedDate  DateTime @default(now())
  photoUrl     String?
  status       String   @default("PENDING_VERIFICATION")
  totalCredits Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  farmer      Farmer       @relation(fields: [farmerId], references: [id])
  project     Project?     @relation(fields: [projectId], references: [id])
  submissions Submission[]
}

model Submission {
  id               String   @id @default(cuid())
  treeId           String
  farmerId         String
  photoUrl         String
  thumbnailUrl     String?
  lat              Float
  lng              Float
  accuracy         Float?
  submittedAt      DateTime @default(now())

  aiScore          Float?
  aiLabels         String?
  aiVerified       Boolean?
  aiVerifiedAt     DateTime?

  status           String   @default("PENDING_AI")
  adminNote        String?
  reviewedBy       String?
  reviewedAt       DateTime?

  distanceFromTree Float?
  locationValid    Boolean?

  tree   Tree   @relation(fields: [treeId], references: [id])
  farmer Farmer @relation(fields: [farmerId], references: [id])
}

model Payment {
  id                    String   @id @default(cuid())
  organizationId        String
  projectId             String
  amount                Float
  currency              String   @default("USD")
  stripePaymentIntentId String?
  stripeStatus          String?
  description           String?
  paidAt                DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])
}

model Payout {
  id               String    @id @default(cuid())
  farmerId         String
  amount           Float
  currency         String    @default("USD")
  month            Int
  year             Int
  treesCount       Int
  approvedDays     Int
  stripeTransferId String?
  status           String    @default("PENDING")
  processedAt      DateTime?
  createdAt        DateTime  @default(now())

  farmer Farmer @relation(fields: [farmerId], references: [id])
}

model CarbonCertificate {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  creditsAmount  Float
  month          Int
  year           Int
  treesCount     Int
  co2Kg          Float
  certificateUrl String?
  issuedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Otp {
  id        String   @id @default(cuid())
  userId    String
  code      String
  type      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
